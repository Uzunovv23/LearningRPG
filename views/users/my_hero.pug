extends ../layout

block content
  .container.mt-5
    .row.justify-content-center
      .col-md-10
        .card.shadow-lg.border-0.mb-5.bg-dark.text-white
          .card-body.text-center.p-5
            .mb-4
                i.fas.fa-user-astronaut.fa-6x.text-warning
            
            h1.display-4.fw-bold.mb-0 #{hero.name}

            - const currentLevel = Math.floor(hero.xp / 1000) + 1
            p.lead.text-warning Герой Ниво #{currentLevel}

            .row.justify-content-center.mt-4
                .col-md-8
                    - const levelProgress = (hero.xp % 1000) / 10
                    
                    h5.d-flex.justify-content-between.small
                        span
                            i.fas.fa-bolt.text-warning.me-2
                            | Опит (XP)
                        span #{hero.xp} XP Общо
                    
                    .progress.mb-2(style="height: 25px; background-color: rgba(255,255,255,0.2);")
                        .progress-bar.bg-warning(
                            role="progressbar" 
                            style=`width: ${levelProgress}%`
                            aria-valuenow=levelProgress 
                            aria-valuemin="0" 
                            aria-valuemax="100"
                        ) #{levelProgress}%
                    
                    p.text-muted.small.fst-italic Още #{1000 - (hero.xp % 1000)} XP до следващо ниво!

        .card.shadow-sm.mb-5.border-0
            .card-header.bg-dark.text-white.p-3.border-bottom-0
                h3.mb-0 
                    i.fas.fa-hiking.me-2
                    | Моята Раница
            
            .card-body.p-4.bg-light
                if !inventory || inventory.length === 0
                    .text-center.py-5.text-muted
                        i.fas.fa-box-open.fa-4x.mb-3.text-secondary(style="opacity: 0.5")
                        h4 Раницата е празна
                        p.mb-0 Нямаш активни артефакти.
                        p Изкарвай оценки 5 и 6 на домашните, за да спечелиш!
                        a.btn.btn-outline-primary.mt-3(href="/items") 
                            i.fas.fa-gem.me-2
                            | Виж наградите
                else
                    .row
                        each slot in inventory
                            .col-md-4.col-lg-3.mb-4
                                .card.h-100.shadow-sm.border-0
                                    - const item = slot.DroppedItem
                                    - let headerClass = 'bg-secondary'
                                    if item.type === 'quiz_help'
                                        - headerClass = 'bg-primary text-white'
                                    else if item.type === 'booster'
                                        - headerClass = 'bg-warning text-dark'
                                    else if item.type === 'time_bender'
                                        - headerClass = 'bg-info text-dark'

                                    .card-header.text-center.py-3(class=headerClass)
                                        i(class=`fas ${item.icon} fa-3x`)
                                    
                                    .card-body.text-center.p-3
                                        h6.fw-bold.mb-1 #{item.name}
                                        small.text-muted.d-block.mb-2 #{item.description}
                                        
                                        button.btn.btn-sm.btn-outline-dark.w-100(disabled title="Скоро!") 
                                            i.fas.fa-hand-sparkles.me-1
                                            | Използвай

        .card.shadow-sm.mb-5.border-0
          .card-header.bg-white.border-bottom.py-3
            h4.mb-0.text-primary 
                i.fas.fa-book-journal-whills.me-2
                | Дневник на приключенията
          
          .card-body.p-4
            if journal.length === 0
                .alert.alert-info.text-center
                    i.fas.fa-info-circle.me-2
                    | Все още не си започнал нито един предмет. Отиди в секция "Мисии"!
            else
                .row
                    each entry in journal
                        .col-md-6.mb-4
                            .card.h-100.shadow-sm.border-light
                                .card-header.bg-light.d-flex.justify-content-between.align-items-center
                                    h5.mb-0.fw-bold= entry.questTitle
                                    if entry.status === 'completed' || entry.status === 'finished'
                                        span.badge.bg-success Завършен
                                    else
                                        span.badge.bg-primary Активен

                                .card-body
                                    .row.text-center.mb-3
                                        .col-6.border-end
                                            h5.text-primary.fw-bold #{entry.xp}
                                            small.text-muted Спечелени XP
                                        .col-6
                                            h5.text-warning.fw-bold #{entry.points}
                                            small.text-muted Спечелени Точки

                                    hr

                                    h6.text-muted.mb-3.small.text-uppercase.fw-bold
                                        i.fas.fa-graduation-cap.me-2
                                        | Купени оценки:
                                    
                                    if entry.grades.length > 0
                                        .d-flex.flex-wrap.gap-2
                                            each grade in entry.grades
                                                - let badgeClass = 'bg-secondary'
                                                if grade.title.includes('6') 
                                                    - badgeClass = 'bg-success'
                                                else if grade.title.includes('5')
                                                    - badgeClass = 'bg-primary'
                                                else if grade.title.includes('4')
                                                    - badgeClass = 'bg-info text-dark'
                                                else if grade.title.includes('3')
                                                    - badgeClass = 'bg-warning text-dark'
                                                
                                                .badge.p-2(class=badgeClass title=grade.description style="font-size: 0.9rem;")
                                                    if grade.icon
                                                        i(class=`fas ${grade.icon} me-1`)
                                                    | #{grade.title}
                                    else
                                        .text-center.py-2
                                            span.badge.bg-light.text-muted.fw-normal Няма закупени оценки