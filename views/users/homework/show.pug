extends ../../layout

block content
  .container.mt-5
    .row.justify-content-center
      .col-md-8
        
        if query && query.error
            .alert.alert-danger #{query.error}
        if query && query.success
            .alert.alert-success #{query.success}

        .card.shadow-lg.border-0.mb-4
          .card-header.bg-primary.text-white.p-4
            .d-flex.justify-content-between.align-items-start
                div
                    h6.text-uppercase.text-warning.mb-2
                        if homework.Quest
                            i.fas.fa-scroll.me-2
                            | #{homework.Quest.title}
                    h2.fw-bold.mb-0 #{homework.title}
                
                - const isExpired = new Date(homework.endDate) < new Date()
                if isExpired
                    span.badge.bg-danger Приключило
                else
                    span.badge.bg-success Активно

          .card-body.p-4
            .row.mb-4
                .col-md-6
                    small.text-muted Начало:
                    div.fw-bold 
                        i.fas.fa-calendar-check.text-success.me-2
                        | #{new Date(homework.startDate).toLocaleString('bg-BG')}
                .col-md-6.text-md-end
                    small.text-muted Краен срок:
                    div.fw-bold(class=isExpired ? 'text-danger' : 'text-primary')
                        i.fas.fa-hourglass-half.me-2
                        | #{new Date(homework.endDate).toLocaleString('bg-BG')}

            hr

            h5.text-primary.mb-3 📝 Условие на задачата
            .bg-light.p-4.rounded.mb-4.border
                // style="white-space: pre-line" запазва новите редове от текста
                p.mb-0(style="white-space: pre-line;") #{homework.description}

            h5.text-primary.mb-3 
                i.fas.fa-paperclip.me-2
                | Материали от учителя
            
            if homework.HomeworkMaterials && homework.HomeworkMaterials.length > 0
                .list-group.mb-4
                    each file in homework.HomeworkMaterials
                        // Линкът води към route-a за сваляне
                        a.list-group-item.list-group-item-action.d-flex.justify-content-between.align-items-center(href=`/users/download/material/${file.id}`)
                            div
                                i.far.fa-file-alt.me-2.text-muted
                                | #{file.fileName}
                            div
                                span.badge.bg-light.text-dark.me-2 Свали
                                i.fas.fa-download.text-primary
            else
                p.text-muted.fst-italic Няма прикачени файлове към това задание.

        .card.shadow.mt-4.border-0
            .card-header.bg-dark.text-white.p-3
                h5.mb-0 
                    i.fas.fa-upload.me-2
                    | Твоето решение

            .card-body.p-4
                if submission
                    .text-center.py-3
                        i.fas.fa-check-circle.text-success.fa-4x.mb-3
                        h3.text-success Предадено успешно!
                        p.text-muted Изпратено на: #{new Date(submission.createdAt).toLocaleString('bg-BG')}
                        
                        .alert.alert-secondary.d-inline-block.mt-2.px-4
                            i.far.fa-file.me-2
                            | #{submission.fileName}
                        
                        if submission.submissionText
                            p.mt-3.fst-italic.text-muted " #{submission.submissionText} "

                        if submission.grade
                             hr
                             h4.fw-bold.text-primary Оценка: #{submission.grade}
                             if submission.feedback
                                .alert.alert-info.mt-2
                                    strong Коментар от учителя: 
                                    | #{submission.feedback}
                        else
                             p.mt-3.text-warning 
                                i.fas.fa-hourglass-half.me-1
                                | Очаква проверка от учител.

                else
                    if isExpired
                        .alert.alert-danger.text-center
                            i.fas.fa-lock.me-2
                            | Срокът за предаване изтече! Вече не можеш да качваш файлове.
                    else
                        form(action=`/users/homework/${homework.id}/submit` method="POST" enctype="multipart/form-data")
                            .mb-3
                                label.form-label.fw-bold(for="solutionFile") Прикачи файл с решение
                                input.form-control(type="file" name="solutionFile" required)
                                .form-text Разрешени формати: PDF, Word, изображения, ZIP.
                            
                            .mb-3
                                label.form-label.fw-bold(for="submissionText") Коментар (по желание)
                                textarea.form-control(name="submissionText" rows="3" placeholder="Здравейте, изпращам решението...")

                            button.btn.btn-success.w-100.btn-lg(type="submit")
                                i.fas.fa-paper-plane.me-2
                                | Предай Домашното