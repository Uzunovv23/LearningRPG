extends ../../layout

block content
  link(rel='stylesheet', href='/stylesheets/homework-items.css')
  
  .container.mt-5
    a.btn.btn-outline-secondary.mb-4(href=`/quests/${homework.questId}`) 
        i.fas.fa-arrow-left.me-2
        | Назад към Куеста

    if query.success
        .alert.alert-success.alert-dismissible.fade.show
            i.fas.fa-check-circle.me-2
            | #{query.success}
            button.btn-close(type="button" data-bs-dismiss="alert")
    if query.error
        .alert.alert-danger.alert-dismissible.fade.show
            i.fas.fa-exclamation-triangle.me-2
            | #{query.error}
            button.btn-close(type="button" data-bs-dismiss="alert")

    .card.shadow-sm.mb-4
        .card-body
            h2.text-primary.fw-bold= homework.title
            
            - let extension = (submission && submission.extensionHours) ? submission.extensionHours : 0
            - let originalDate = new Date(homework.endDate)
            - let effectiveDate = new Date(originalDate.getTime() + extension * 60 * 60 * 1000)
            - let isExpired = effectiveDate < new Date()
            
            p.text-muted.mb-2
                i.far.fa-clock.me-2
                | Краен срок: <strong>#{effectiveDate.toLocaleString('bg-BG')}</strong>
                if extension > 0
                    span.badge.bg-info.text-dark.ms-2 +#{extension} часа
            
            if homework.description
                hr
                p.lead= homework.description

            if homework.HomeworkMaterials && homework.HomeworkMaterials.length > 0
                h5.mt-4 Материали:
                ul
                    each mat in homework.HomeworkMaterials
                        li
                            a(href=`/users/download/material/${mat.id}`) 
                                i.fas.fa-download.me-2
                                | #{mat.title || 'Свали файл'}

    .card.shadow
        .card-header.bg-light.py-3
            h4.mb-0 Вашето решение
        
        .card-body.p-4
            
            if submission && (submission.status === 'submitted' || submission.status === 'graded' || submission.grade)
                .alert.alert-success
                    h4.alert-heading Добра работа!
                    p Решението е предадено успешно на #{new Date(submission.updatedAt).toLocaleString('bg-BG')}.
                    
                    if submission.usedLatePass
                        hr
                        p.mb-0.text-warning 
                            i.fas.fa-ticket-alt.me-2
                            | Използван е Билет за закъснение.

                if submission.SubmissionFiles && submission.SubmissionFiles.length > 0
                    h5.mt-4 Качени файлове:
                    ul.list-group.mb-3
                        each file in submission.SubmissionFiles
                            li.list-group-item.d-flex.justify-content-between.align-items-center
                                span
                                    i.fas.fa-file.me-2
                                    | #{file.fileName}
                                div
                                    a.btn.btn-sm.btn-primary.me-2(href=`/users/homework/file/${file.id}/download`) Свали
                                    if !isExpired && !submission.grade
                                        form(action=`/users/homework/file/${file.id}/delete` method="POST" style="display:inline")
                                            button.btn.btn-sm.btn-danger(type="submit") Изтрий
                
                if submission.grade
                    .mt-4.p-3.bg-light.border.rounded.text-center
                        h3 Оценка: 
                            span.text-success #{submission.grade} 
                        if submission.feedback
                            p.text-muted.mt-2 Коментар: #{submission.feedback}
                else
                    .mt-3.text-muted 
                        i.fas.fa-spinner.fa-spin.me-2
                        | Очаква се оценяване...

            else
                
                if isExpired
                    if latePassCount > 0
                        .alert.badge-late-pass.p-4.mb-4.rounded
                            .d-flex.align-items-center
                                i.fas.fa-ticket-alt.fa-3x.me-4
                                div
                                    h4.alert-heading Закъсняхте!
                                    p.mb-0 Не се притеснявайте! Имате <strong>#{latePassCount} Билета за закъснение</strong>.
                                    p.mb-0 Един билет ще бъде използван автоматично, когато натиснете "Предай".
                        
                        +submissionForm(homework, true)
                        
                    else
                        .alert.alert-danger.text-center.p-5
                            i.fas.fa-lock.fa-3x.mb-3
                            h3 Крайният срок изтече!
                            p Нямате "Билет за Закъснение" в инвентара си.
                            a.btn.btn-outline-primary.mt-2(href="/quests") Към куестовете

                else
                    +submissionForm(homework, false)

mixin submissionForm(homework, isLate)
    form(action=`/users/homework/${homework.id}/submit` method="POST" enctype="multipart/form-data")
        .mb-3
            label.form-label(for="submissionText") Текстово решение / Коментар
            textarea.form-control(name="submissionText" rows="4" placeholder="Напишете нещо тук...")
        
        .mb-4
            label.form-label(for="solutionFiles") Прикачи файлове
            input.form-control(type="file" name="solutionFiles" multiple)
        
        if isLate
            button.btn.btn-warning.btn-lg.w-100.fw-bold(type="submit") 
                i.fas.fa-ticket-alt.me-2
                | Предай с Билет
        else
            button.btn.btn-success.btn-lg.w-100(type="submit") 
                i.fas.fa-paper-plane.me-2
                | Предай решението