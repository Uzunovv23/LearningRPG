extends ../layout

block content
  .container.mt-5
    .row.justify-content-center
      .col-lg-8
        
        .text-center.mb-5
          h1.display-4.text-primary= quest.title
          p.lead.text-muted= quest.description
          span.badge.bg-warning.text-dark XP Reward: #{quest.xpReward}

        .card.shadow-sm.border-0
          .card-header.bg-dark.text-white
            h3.mb-0 Available Quizzes
          
          .list-group.list-group-flush
            if quest.Quizzes && quest.Quizzes.length > 0
              each quiz in quest.Quizzes
                a.list-group-item.list-group-item-action.d-flex.justify-content-between.align-items-center.p-4(
                  href=`/quests/${quest.id}/quizzes/${quiz.id}`
                )
                  div
                    h5.mb-1.text-primary= quiz.title
                    small.text-muted Click to start this challenge
                  
                  i.fas.fa-chevron-right.text-muted
            else
              .p-4.text-center.text-muted
                p No quizzes available yet.
        
        .mt-4.text-center
            a.btn.btn-outline-secondary(href="/quests") Back to All Quests