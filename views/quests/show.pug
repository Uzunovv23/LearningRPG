extends ../layout

block content
  link(rel='stylesheet', href='/stylesheets/homework-items.css')

  .container.mt-5
    
    if alertMessage
      div(class=`alert alert-${alertType === 'success' ? 'success' : 'danger'} alert-dismissible fade show` role="alert")
        strong #{alertType === 'success' ? 'Успех!' : 'Грешка!'} 
        |  #{alertMessage}
        button.btn-close(type="button" data-bs-dismiss="alert" aria-label="Close")

    .jumbotron.p-5.bg-dark.text-white.rounded.mb-5.shadow
      .d-md-flex.justify-content-between.align-items-center
        div
            h1.display-4.fw-bold #{quest.title}
            p.lead.mb-0 #{quest.description}
            if isCompleted
                .badge.bg-success.mt-3.fs-6 Предметът е завършен
        
        div.mt-4.mt-md-0
            if !isEnrolled
                form(action=`/quests/${quest.id}/enroll` method="POST")
                    button.btn.btn-warning.btn-lg.fw-bold.px-5(type="submit") Запиши се
            else
                .text-end
                    .badge.bg-primary.fs-6 Записан

    .row
        .col-md-6.mb-5
            h3.mb-3.text-secondary
                i.fas.fa-tasks.me-2
                | Тестове
            
            if quest.Quizzes && quest.Quizzes.length > 0
                .list-group.shadow-sm
                    each quiz in quest.Quizzes
                        a.list-group-item.list-group-item-action.d-flex.justify-content-between.align-items-center(href=`/quests/${quest.id}/quizzes/${quiz.id}`)
                            div
                                h5.mb-1 #{quiz.title}
                            span.badge.bg-warning.text-dark #{quiz.xpReward} XP
            else
                .alert.alert-light.border Няма добавени тестове.

        .col-md-6.mb-5
            h3.mb-3.text-primary
                i.fas.fa-book-reader.me-2
                | Домашни работи
            
            if quest.Homework && quest.Homework.length > 0
                .list-group.shadow-sm
                    each hw in quest.Homework
                        - const mySub = hw.HomeworkSubmissions && hw.HomeworkSubmissions[0]
                        
                        - const hasFiles = mySub && mySub.SubmissionFiles && mySub.SubmissionFiles.length > 0
                        - const isGraded = mySub && (mySub.grade || mySub.status === 'graded')
                        - const isSubmitted = mySub && (mySub.status === 'submitted' || hasFiles)
                        
                        - let extension = (mySub && mySub.extensionHours) ? mySub.extensionHours : 0
                        - let originalDate = new Date(hw.endDate)
                        - let effectiveDate = new Date(originalDate.getTime() + extension * 60 * 60 * 1000)
                        - const isExpired = effectiveDate < new Date()

                        .list-group-item.flex-column.align-items-start
                            .d-flex.w-100.justify-content-between.mb-2
                                h5.mb-1.fw-bold 
                                    a.text-decoration-none.text-dark(href=`/users/homework/${hw.id}`) #{hw.title}
                                    
                                    if extension > 0
                                        span.badge.bg-info.text-dark.ms-2(title="Удължен срок") +#{extension}ч
                                    if mySub && mySub.usedLatePass
                                        span.badge.bg-warning.text-dark.ms-2(title="Ползван Билет") Билет

                                small
                                    if isGraded
                                        span.badge.bg-success Оценка: #{mySub.grade}
                                    else if isSubmitted
                                        span.badge.bg-warning.text-dark Предадено
                                    else if isExpired
                                        span.badge.bg-danger Изтекъл срок
                                    else
                                        span.badge.bg-primary Активно

                            p.mb-1
                                i.far.fa-clock.me-1
                                | Краен срок: #{effectiveDate.toLocaleString('bg-BG')}
                            
                            if !isExpired && !isSubmitted && !isGraded
                                if chronoCount > 0
                                    button.btn.btn-sm.btn-outline-info.btn-chrono.mt-2(
                                        data-homework-id=hw.id
                                        title="Удължи с 24 часа"
                                    ) 
                                        i.fas.fa-hourglass-half.me-1
                                        | Удължи (+24ч) (Имаш: #{chronoCount})

                            - const isAdmin = (typeof user !== 'undefined' && user.role === 'admin') || (typeof currentUser !== 'undefined' && currentUser.role === 'admin')
                            
                            if isAdmin
                                - const subCount = hw.HomeworkSubmissions ? hw.HomeworkSubmissions.length : 0
                                
                                if subCount > 0
                                    a.btn.btn-sm.btn-dark.mt-2.ms-2(href=`/admin/homework/${hw.id}/submissions`)
                                        i.fas.fa-gavel.me-1
                                        | Оценяване на предадени домашни
                                else
                                    button.btn.btn-sm.btn-secondary.mt-2.ms-2(disabled)
                                        i.fas.fa-ban.me-1
                                        | Няма предадени домашни

            else
                .alert.alert-light.border.text-muted Все още няма домашни.

  script(src='/javascripts/homework-items.js')