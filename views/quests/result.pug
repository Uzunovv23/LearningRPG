extends ../layout

block content
  link(rel='stylesheet', href='/stylesheets/quest-result.css')

  .container.mt-5
    .row.justify-content-center
      .col-md-8
        .card.result-card.text-white.mb-5
          .card-header.text-center.border-secondary
            h4.mb-0.text-muted Резултат от Мисията

          .card-body.text-center.py-5
            h1.display-5.text-primary.mb-4 #{questTitle}

            if message
              div(class=`alert mb-4 ${isSuccess ? 'alert-success' : 'alert-warning'}`)
                i(class=`fas ${isSuccess ? 'fa-check-circle' : 'fa-exclamation-triangle'} me-2`)
                | #{message}

            .score-container.mb-4
              h2.mb-2
                span.text-muted Точки: 
                span#scoreDisplay.score-value(
                  class=points > 0 ? "text-success-glow" : "text-danger-glow",
                  data-target=points
                ) 0
                span.text-muted  / #{maxPoints}
              
              p.lead
                | Верни отговори: 
                strong #{correctCount}

            hr.border-secondary.my-4

            if xpEarned > 0 || coinsEarned > 0
              .reward-box.mb-4
                h4.text-light.mb-3 Спечелени награди:
                
                .d-flex.justify-content-center.align-items-center.gap-5.flex-wrap
                    
                    if xpEarned > 0
                        .reward-item
                            h3.text-success.mb-0 
                              | + 
                              span#xpDisplay(data-target=xpEarned) 0 
                              |  XP
                            i.fas.fa-bolt.fa-2x.text-success.mt-2

                    if coinsEarned > 0
                        .reward-item
                            h3.text-warning.mb-0 
                              | + 
                              span#coinsDisplay(data-target=coinsEarned) 0 
                              |  KC
                            i.fas.fa-coins.fa-2x.text-warning.mt-2

                p.mb-0.text-light.mt-4 Поздравления! Героят ти стана по-силен и по-богат!
            
            else
              .reward-box.failed.mb-4
                .d-flex.justify-content-center.gap-4.mb-2
                    h3.text-muted 0 XP
                    h3.text-muted 0 KC
                
                if isSuccess
                   p.mb-0.text-light Вече си усвоил това знание! (Наградите се дават еднократно)
                   i.fas.fa-check-double.fa-3x.text-muted.mt-3
                else
                   p.mb-0.text-light Не се отказвай! Упражнявай се и опитай пак.
            
            a.btn.btn-primary.btn-lg.mt-3(href='/quests') 
              | Обратно към мисиите

  script(src='/javascripts/quest-result.js')