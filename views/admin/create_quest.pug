extends ../layout

block content
  link(rel='stylesheet', href='/stylesheets/admin.css')

  .container.mt-5
    h2.mb-4.text-primary Създаване на нов Куест
    
    .card.mb-4.shadow-sm
      .card-header.bg-primary.text-white Основна информация
      .card-body
        .row
          // Промяна: Вече е col-12 и няма input за общо XP
          .col-12
            .mb-3
              label.form-label Заглавие на Куеста (напр. "Математика 1. клас")
              input#questTitle.form-control(type="text")
        
        .mb-3
          label.form-label Описание
          textarea#questDesc.form-control(rows="3")

    #quizzesContainer

    .d-flex.justify-content-between.mb-5.pb-5
      button.btn.btn-outline-dark.btn-lg#addQuizBtn(type="button") 
        i.bi.bi-folder-plus 
        |  + Добави Раздел (Quiz)
      
      button.btn.btn-success.btn-lg#saveQuestBtn(type="button") 
        | ЗАПАЗИ ВСИЧКО

  script(src='/javascripts/admin_quest.js')