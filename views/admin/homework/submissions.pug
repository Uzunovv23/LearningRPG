extends ../../layout

block content
  link(rel='stylesheet', href='/stylesheets/admin_submissions.css')

  .rpg-theme
    .container-fluid.px-4.px-lg-5.rpg-container
      .d-flex.justify-content-between.align-items-center.mb-4
          h2
              i.fas.fa-book-reader.me-2.text-rpg-gold
              | Предавания: #{homework.title}
          a.btn.rpg-btn.rpg-btn-edit(href=`/users/homework/${homework.id}`) 
              i.fas.fa-arrow-left.me-2
              | Обратно към условието

      if query && query.success
          .rpg-alert.rpg-alert-success 
            i.fas.fa-check-circle.me-2
            | #{query.success}

      - const validSubmissions = homework.HomeworkSubmissions ? homework.HomeworkSubmissions.filter(s => s.status === 'submitted' || s.status === 'graded' || (s.SubmissionFiles && s.SubmissionFiles.length > 0) || (s.submissionText && s.submissionText.trim() !== '')) : []

      if validSubmissions.length === 0
          .rpg-alert.rpg-alert-info.justify-content-center
              i.fas.fa-info-circle.me-2
              | Все още няма предадени решения от ученици.
      else
          .card.rpg-card
            .card-body
              .table-responsive
                  table.table.rpg-table.align-middle
                      thead
                          tr
                              th #
                              th Ученик
                              th Статус / Дата
                              th Файлове
                              th Оценка
                              th Действия
                      tbody
                          
                          each sub, index in validSubmissions
                              tr
                                  td #{index + 1}
                                  td 
                                      div.fw-bold.text-light #{sub.User.username}
                                      if sub.User.Hero
                                          small.text-muted 
                                              i.fas.fa-user-shield.me-1.text-info
                                              | #{sub.User.Hero.name}
                                  td 
                                      div #{new Date(sub.updatedAt).toLocaleString('bg-BG')}
                                      if sub.submissionText
                                          small.text-muted.d-block.mt-1
                                              i.fas.fa-comment-dots.me-1.text-warning
                                              if sub.submissionText.length > 35
                                                  | "#{sub.submissionText.substring(0, 35)}..."
                                                  button.btn.btn-link.text-info.p-0.ms-1.read-more-btn(
                                                      type="button" 
                                                      data-bs-toggle="modal" 
                                                      data-bs-target="#textModal" 
                                                      data-text=sub.submissionText
                                                  ) [Виж цялото]
                                              else
                                                  | "#{sub.submissionText}"
                                  td
                                      if sub.SubmissionFiles && sub.SubmissionFiles.length > 0
                                          ul.list-unstyled.mb-0
                                              each file in sub.SubmissionFiles
                                                  li.mb-1
                                                      a.text-info.text-decoration-none(href=`/users/homework/file/${file.id}/download`)
                                                          i.far.fa-file-alt.me-1
                                                          | #{file.fileName}
                                      else
                                          span.text-muted -
                                  td
                                      if sub.grade
                                          span.badge.bg-success.rpg-badge Оценка: #{sub.grade}
                                      else
                                          span.badge.bg-secondary.rpg-badge Неоценен
                                  td
                                      
                                      button.btn.rpg-btn.rpg-btn-role.grade-btn(
                                          data-id=sub.id
                                          data-grade=sub.grade || ""
                                          data-feedback=sub.feedback || ""
                                      )
                                          i.fas.fa-check-double.me-1
                                          | Оцени

      
      #gradeModal.modal.fade.rpg-modal(tabindex="-1" aria-hidden="true")
          .modal-dialog.modal-dialog-centered
              .modal-content
                  form#gradeForm(method="POST")
                      .modal-header
                          h5.modal-title 
                            i.fas.fa-gavel.me-2
                            | Оценяване на домашно
                          button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
                      
                      .modal-body
                          .mb-3
                              label.form-label.rpg-label(for="gradeSelect") Оценка (2 - 6)
                              select#gradeSelect.form-select.rpg-input(name="grade" required)
                                  option(value="" disabled selected style="color: #64748b;") Избери оценка...
                                  option(value="2" style="background: #161d2e;") Слаб (2)
                                  option(value="3" style="background: #161d2e;") Среден (3)
                                  option(value="4" style="background: #161d2e;") Добър (4)
                                  option(value="5" style="background: #161d2e;") Много добър (5)
                                  option(value="6" style="background: #161d2e;") Отличен (6)
                          
                          .mb-3
                              label.form-label.rpg-label(for="feedbackText") Коментар (Обратна връзка)
                              textarea#feedbackText.form-control.rpg-input(name="feedback" rows="3" placeholder="Браво! Справил си се отлично, но...")

                      .modal-footer
                          button.btn.rpg-btn.rpg-btn-edit(type="button" data-bs-dismiss="modal") Отказ
                          button.btn.rpg-btn.rpg-btn-role(type="submit")
                              i.fas.fa-save.me-2
                              | Запиши Оценката

      #textModal.modal.fade.rpg-modal(tabindex="-1" aria-hidden="true")
          .modal-dialog.modal-dialog-centered.modal-dialog-scrollable.modal-lg
              .modal-content
                  .modal-header
                      h5.modal-title 
                          i.fas.fa-book-open.me-2
                          | Пълно текстово решение
                      button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
                  .modal-body.p-4
                      p#fullTextContainer.text-light.mb-0(style="white-space: pre-wrap; font-size: 1.15rem; line-height: 1.6;")
                  .modal-footer
                      button.btn.rpg-btn.rpg-btn-edit(type="button" data-bs-dismiss="modal") Затвори

  script(src='/javascripts/admin_submissions.js')