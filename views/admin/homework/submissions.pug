extends ../../layout

block content
  .container.mt-5
    .d-flex.justify-content-between.align-items-center.mb-4
        h2
            i.fas.fa-book-reader.me-2
            | Предавания: #{homework.title}
        a.btn.btn-outline-secondary(href=`/users/homework/${homework.id}`) 
            i.fas.fa-arrow-left.me-2
            | Обратно към условието

    if query && query.success
        .alert.alert-success #{query.success}

    if homework.HomeworkSubmissions.length === 0
        .alert.alert-info.text-center
            i.fas.fa-info-circle.me-2
            | Все още няма предадени решения от ученици.
    else
        .table-responsive
            table.table.table-hover.table-bordered.shadow-sm.bg-white
                thead.table-dark
                    tr
                        th #
                        th Ученик
                        th Статус / Дата
                        th Файлове
                        th Оценка
                        th Действия
                tbody
                    each sub, index in homework.HomeworkSubmissions
                        tr
                            td #{index + 1}
                            td 
                                div.fw-bold #{sub.User.username}
                                if sub.User.Hero
                                    small.text-muted 
                                        i.fas.fa-user-shield.me-1
                                        | #{sub.User.Hero.name}
                            td 
                                div #{new Date(sub.updatedAt).toLocaleString('bg-BG')}
                                if sub.submissionText
                                    small.text-muted.d-block.mt-1
                                        i.fas.fa-comment-dots.me-1
                                        | "#{sub.submissionText.substring(0, 30)}..."
                            td
                                if sub.SubmissionFiles && sub.SubmissionFiles.length > 0
                                    ul.list-unstyled.mb-0
                                        each file in sub.SubmissionFiles
                                            li.mb-1
                                                a.text-decoration-none(href=`/users/homework/file/${file.id}/download`)
                                                    i.far.fa-file.me-1
                                                    | #{file.fileName}
                                else
                                    span.text-muted -
                            td
                                if sub.grade
                                    span.badge.bg-success.fs-6 #{sub.grade}
                                else
                                    span.badge.bg-secondary Неоценен
                            td
                                button.btn.btn-primary.btn-sm(
                                    onclick=`openGradeModal('${sub.id}', '${sub.grade || ""}', '${sub.feedback || ""}')`
                                )
                                    i.fas.fa-check-double.me-1
                                    | Оцени

    #gradeModal.modal.fade(tabindex="-1" aria-hidden="true")
        .modal-dialog
            .modal-content
                form#gradeForm(method="POST")
                    .modal-header.bg-primary.text-white
                        h5.modal-title Оценяване на домашно
                        button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal" aria-label="Close")
                    
                    .modal-body
                        .mb-3
                            label.form-label.fw-bold(for="gradeSelect") Оценка (2 - 6)
                            select#gradeSelect.form-select(name="grade" required)
                                option(value="" disabled selected) Избери оценка...
                                option(value="2") Слаб (2)
                                option(value="3") Среден (3)
                                option(value="4") Добър (4)
                                option(value="5") Много добър (5)
                                option(value="6") Отличен (6)
                        
                        .mb-3
                            label.form-label.fw-bold(for="feedbackText") Коментар (Обратна връзка)
                            textarea#feedbackText.form-control(name="feedback" rows="3" placeholder="Браво! Справил си се отлично, но...")

                    .modal-footer
                        button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Отказ
                        button.btn.btn-success(type="submit")
                            i.fas.fa-save.me-2
                            | Запиши Оценката

    script.
        function openGradeModal(submissionId, currentGrade, currentFeedback) {
            const form = document.getElementById('gradeForm');
            form.action = `/admin/submission/${submissionId}/grade`;

            const select = document.getElementById('gradeSelect');
            if (currentGrade) {
                select.value = currentGrade;
            } else {
                select.value = ""; 
            }

            const textarea = document.getElementById('feedbackText');
            textarea.value = currentFeedback || "";

            const modalElement = document.getElementById('gradeModal');
            const modal = new bootstrap.Modal(modalElement);
            modal.show();
        }