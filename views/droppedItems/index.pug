extends ../layout

block styles
  link(rel='stylesheet', href='/stylesheets/dropped-items.css')

block content
  .container-fluid.dropped-items-container
    
    .header-section
      .header-content
        .header-title-wrapper
          h1.header-title.glow-text
            i.fas.fa-gem.me-3
            | Артефакти на Знанието

          .header-subtitle
            p.lead.subtitle-text
              | Специални магически предмети, които печелиш чрез отлични оценки на
              strong.text-golden
                | &nbsp;Домашни работи!

        .header-decoration
          .star-burst
          .star-burst.delay-1
          .star-burst.delay-2

    
    .unlock-section
      .unlock-header
        i.fas.fa-scroll.me-2
        span Как да отключиш Артефакти?
      .unlock-content
        p.unlock-description Когато учителят оцени твоето домашно, системата автоматично хвърля зарчето (RNG).
        .unlock-info-container
          .unlock-info-item
            .unlock-grade-badge
              i.fas.fa-star
              span 5
            .unlock-grade-label Много добър
            .unlock-grade-reward
              i.fas.fa-gift.me-2
              span Шанс за 1 Артефакт

          .unlock-divider

          .unlock-info-item
            .unlock-grade-badge
              i.fas.fa-trophy
              span 6
            .unlock-grade-label Отличен
            .unlock-grade-reward
              i.fas.fa-gifts.me-2
              span Шанс за 2 Артефакта!

    
    .items-section
      .items-header
        h2.items-title
          i.fas.fa-wand-magic-sparkles.me-2
          | Възможни Награди

        .items-divider

      if items && items.length === 0
        .empty-state
          .empty-icon
            i.fas.fa-inbox
          h3.empty-title Няма намерени артефакти
          p.empty-description Базата е празна
      else if items && items.length > 0
        .items-grid
          each item, index in items
            .item-card-wrapper(data-item-index=index)
              .item-card
                
                .item-rarity-glow

                
                .item-card-front
                  .item-header
                    - let headerGradient = 'header-primary'
                    - let typeName = ''
                    - let customIcon = 'fas fa-star' 

                    if item.type === 'quiz_help'
                      - headerGradient = 'header-quiz'
                      - typeName = 'Помощ за Тест'
                    else if item.type === 'booster'
                      - headerGradient = 'header-booster'
                      - typeName = 'Усилвател (XP/Coins)'
                    else if item.type === 'time_bender'
                      - headerGradient = 'header-time'
                      - typeName = 'Контрол на Времето'

                    
                    if item.name === 'Еликсир на паметта'
                      - customIcon = 'fas fa-flask'
                    else if item.name === 'Жокера'
                      - customIcon = 'fas fa-mask'
                    else if item.name === 'Свитък на Мъдростта'
                      - customIcon = 'fas fa-scroll'
                    else if item.name === 'Ръкавицата на Мидас'
                      - customIcon = 'fas fa-hand-holding-usd'
                    else if item.name === 'Пясъчен часовник'
                      - customIcon = 'fas fa-hourglass-half'
                    else if item.name === 'Билет за Закъснение'
                      - customIcon = 'fas fa-ticket-alt'

                    .item-header-content(class=headerGradient)
                      .item-icon-wrapper
                        if item.icon && item.icon.trim() !== ''
                          - const hasBaseClass = item.icon.includes('fas ') || item.icon.includes('fab ') || item.icon.includes('far ') || item.icon.includes('fa-solid ');
                          - const finalIcon = hasBaseClass ? item.icon : `fas ${item.icon}`
                          i(class=finalIcon)
                        else
                          i(class=customIcon)

                  .item-body
                    .item-name-section
                      h4.item-name #{item.name}

                    .item-description-section
                      p.item-description #{item.description}

                    .item-type-badge
                      span.badge-text #{typeName}

                    .item-hover-effect

    script(src='/javascripts/dropped-items.js')