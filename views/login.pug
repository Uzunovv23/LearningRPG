extends layout

block content
  .container.mt-5
    .row.justify-content-center
      .col-md-6
        .card
          .card-header.bg-success.text-white Вход в играта
          .card-body
            form(action="/login" method="POST")
              .mb-3
                label.form-label Имейл
                input.form-control(type="email" name="email" required)
              .mb-3
                label.form-label Парола
                input.form-control(type="password" name="password" required)
              button.btn.btn-primary.w-100(type="submit") Влез
            
            p.mt-3.text-center
              | Нямаш герой? 
              a(href="/register") Регистрирай се